{
  "name": "shopmonkey-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Shopmonkey REST API (v3) — work orders, customers, vehicles, inventory, and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shopmonkey-mcp-server": "dist/index.js",
    "shopmonkey-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/tests/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AbbottDevelopments/shopmonkey-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/AbbottDevelopments/shopmonkey-mcp-server/issues"
  },
  "homepage": "https://github.com/AbbottDevelopments/shopmonkey-mcp-server#readme",
  "keywords": [
    "mcp",
    "shopmonkey",
    "model-context-protocol",
    "ai",
    "auto-repair",
    "shop-management"
  ],
  "author": "AbbottDevelopments",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.3"
  }
}
