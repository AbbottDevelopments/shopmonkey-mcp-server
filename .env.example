# Shopmonkey API Key (required)
# Create at: Shopmonkey Settings > Integration > API Keys
SHOPMONKEY_API_KEY=your_long_lived_api_key_here

# Shopmonkey API Base URL (optional, defaults to production)
SHOPMONKEY_BASE_URL=https://api.shopmonkey.cloud/v3

# Location ID for multi-location shops (optional)
SHOPMONKEY_LOCATION_ID=

# Bearer token for HTTP transport authentication (required for cloud deployment)
# WARNING: Omitting this makes the HTTP endpoint publicly accessible.
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# HTTP transport port (optional, default: 3000)
# Railway sets this automatically — do not set when deploying to Railway.
PORT=3000
